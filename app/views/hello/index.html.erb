<div class="container">
  <div style="text-align: center; padding: 60px 20px;">
    <h1 style="font-size: 48px; color: #2c3e50; margin-bottom: 20px;">
      Bem-vindo ao ProcStudio
    </h1>
    
    <% if logged_in? %>
      <p style="font-size: 20px; color: #666; margin-bottom: 30px;">
        Olá, <%= current_user.email %>!
      </p>
      <div style="display: flex; gap: 20px; justify-content: center;">
        <%= link_to "Gerenciar Usuários", users_path, class: "btn btn-primary" %>
        <%= link_to "Criar Novo Usuário", new_user_path, class: "btn btn-secondary" %>
      </div>
    <% else %>
      <p style="font-size: 20px; color: #666; margin-bottom: 30px;">
        Sistema de Gestão Jurídica
      </p>
      <div style="display: flex; gap: 20px; justify-content: center;">
        <%= link_to "Fazer Login", login_path, class: "btn btn-primary" %>
        <%= link_to "Registrar-se", register_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>