<div class="container mx-auto px-4 py-8">
  <div x-data="customerForm()" 
       x-init="init()"
       class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl mb-6">
        <%= @customer.persisted? ? 'Editar Cliente' : 'Novo Cliente' %>
      </h2>

      <!-- Multi-step indicator -->
      <ul class="steps w-full mb-6" x-show="showGuardianForm">
        <li class="step" :class="{ 'step-primary': currentStep >= 1 }">Dados do Cliente</li>
        <li class="step" :class="{ 'step-primary': currentStep >= 2 }">
          <span x-text="guardianLabel"></span>
        </li>
      </ul>

      <%= form_with model: @customer, local: false, html: { 
        'x-on:submit.prevent': 'handleSubmit',
        class: 'space-y-6'
      } do |f| %>
        
        <!-- Step 1: Customer Information -->
        <div x-show="currentStep === 1">
          <!-- Customer Type Selection -->
          <div class="form-control w-full mb-4">
            <label class="label">
              <span class="label-text">Tipo de Cliente</span>
            </label>
            <select x-model="formData.customer_type" 
                    class="select select-bordered w-full">
              <option value="physical_person">Pessoa Física</option>
              <option value="legal_person">Pessoa Jurídica</option>
            </select>
          </div>

          <!-- Personal Information Section -->
          <div class="divider">Informações Pessoais</div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Name -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">Nome *</span>
              </label>
              <input type="text" 
                     x-model="formData.name"
                     @blur="validateField('name', formData.name)"
                     class="input input-bordered w-full"
                     :class="{ 'input-error': errors.name && touched.name }"
                     placeholder="Digite o nome" />
              <label class="label" x-show="errors.name && touched.name">
                <span class="label-text-alt text-error" x-text="errors.name"></span>
              </label>
            </div>

            <!-- Last Name -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">Sobrenome *</span>
              </label>
              <input type="text" 
                     x-model="formData.last_name"
                     @blur="validateField('last_name', formData.last_name)"
                     class="input input-bordered w-full"
                     :class="{ 'input-error': errors.last_name && touched.last_name }"
                     placeholder="Digite o sobrenome" />
              <label class="label" x-show="errors.last_name && touched.last_name">
                <span class="label-text-alt text-error" x-text="errors.last_name"></span>
              </label>
            </div>

            <!-- CPF -->
            <div class="form-control w-full" x-show="formData.customer_type === 'physical_person'">
              <label class="label">
                <span class="label-text">CPF *</span>
              </label>
              <input type="text" 
                     x-model="formData.cpf"
                     @input="formData.cpf = formatCPF($event.target.value)"
                     @blur="validateField('cpf', formData.cpf)"
                     class="input input-bordered w-full"
                     :class="{ 'input-error': errors.cpf && touched.cpf }"
                     placeholder="000.000.000-00"
                     maxlength="14" />
              <label class="label" x-show="errors.cpf && touched.cpf">
                <span class="label-text-alt text-error" x-text="errors.cpf"></span>
              </label>
            </div>

            <!-- CNPJ -->
            <div class="form-control w-full" x-show="formData.customer_type === 'legal_person'">
              <label class="label">
                <span class="label-text">CNPJ *</span>
              </label>
              <input type="text" 
                     x-model="formData.cnpj"
                     @input="formData.cnpj = formatCNPJ($event.target.value)"
                     @blur="validateField('cnpj', formData.cnpj)"
                     class="input input-bordered w-full"
                     :class="{ 'input-error': errors.cnpj && touched.cnpj }"
                     placeholder="00.000.000/0000-00"
                     maxlength="18" />
              <label class="label" x-show="errors.cnpj && touched.cnpj">
                <span class="label-text-alt text-error" x-text="errors.cnpj"></span>
              </label>
            </div>

            <!-- RG -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">RG *</span>
              </label>
              <input type="text" 
                     x-model="formData.rg"
                     @blur="validateField('rg', formData.rg)"
                     class="input input-bordered w-full"
                     :class="{ 'input-error': errors.rg && touched.rg }"
                     placeholder="Digite o RG" />
              <label class="label" x-show="errors.rg && touched.rg">
                <span class="label-text-alt text-error" x-text="errors.rg"></span>
              </label>
            </div>

            <!-- Birth Date -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">Data de Nascimento *</span>
              </label>
              <input type="date" 
                     x-model="formData.birth"
                     @change="handleBirthDateChange"
                     class="input input-bordered w-full"
                     :class="{ 'input-error': errors.birth && touched.birth }" />
              <label class="label" x-show="errors.birth && touched.birth">
                <span class="label-text-alt text-error" x-text="errors.birth"></span>
              </label>
            </div>

            <!-- Gender -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">Gênero</span>
              </label>
              <select x-model="formData.gender" class="select select-bordered w-full">
                <option value="">Selecione</option>
                <option value="male">Masculino</option>
                <option value="female">Feminino</option>
                <option value="other">Outro</option>
              </select>
            </div>

            <!-- Civil Status -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">Estado Civil</span>
              </label>
              <select x-model="formData.civil_status" class="select select-bordered w-full">
                <option value="">Selecione</option>
                <option value="single">Solteiro(a)</option>
                <option value="married">Casado(a)</option>
                <option value="divorced">Divorciado(a)</option>
                <option value="widowed">Viúvo(a)</option>
                <option value="separated">Separado(a)</option>
              </select>
            </div>

            <!-- Capacity -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">Capacidade Civil</span>
              </label>
              <select x-model="formData.capacity" 
                      @change="handleCapacityChange"
                      class="select select-bordered w-full">
                <option value="able">Capaz</option>
                <option value="relatively_incapable">Relativamente Incapaz</option>
                <option value="unable">Incapaz</option>
              </select>
            </div>

            <!-- Mother's Name -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">Nome da Mãe *</span>
              </label>
              <input type="text" 
                     x-model="formData.mother_name"
                     @blur="validateField('mother_name', formData.mother_name)"
                     class="input input-bordered w-full"
                     :class="{ 'input-error': errors.mother_name && touched.mother_name }"
                     placeholder="Digite o nome da mãe" />
              <label class="label" x-show="errors.mother_name && touched.mother_name">
                <span class="label-text-alt text-error" x-text="errors.mother_name"></span>
              </label>
            </div>

            <!-- Profession -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">Profissão <span x-show="formData.capacity !== 'unable'">*</span></span>
              </label>
              <input type="text" 
                     x-model="formData.profession"
                     @blur="validateField('profession', formData.profession)"
                     class="input input-bordered w-full"
                     :class="{ 'input-error': errors.profession && touched.profession }"
                     placeholder="Digite a profissão"
                     :disabled="formData.capacity === 'unable'" />
              <label class="label" x-show="errors.profession && touched.profession">
                <span class="label-text-alt text-error" x-text="errors.profession"></span>
              </label>
            </div>
          </div>

          <!-- Contact Information Section -->
          <div class="divider">Informações de Contato</div>

          <!-- Phone Numbers -->
          <div class="form-control w-full mb-4">
            <label class="label">
              <span class="label-text">Telefones</span>
            </label>
            <template x-for="(phone, index) in formData.phones" :key="index">
              <div class="flex gap-2 mb-2">
                <input type="text" 
                       x-model="phone.phone_number"
                       @input="phone.phone_number = formatPhone($event.target.value)"
                       class="input input-bordered flex-1"
                       placeholder="(00) 00000-0000" />
                <button type="button"
                        @click="removePhone(index)"
                        class="btn btn-error btn-outline"
                        x-show="formData.phones.length > 1">
                  Remover
                </button>
              </div>
            </template>
            <button type="button" 
                    @click="addPhone"
                    class="btn btn-sm btn-primary btn-outline mt-2">
              + Adicionar Telefone
            </button>
          </div>

          <!-- Email Addresses -->
          <div class="form-control w-full mb-4">
            <label class="label">
              <span class="label-text">E-mails</span>
            </label>
            <template x-for="(email, index) in formData.emails" :key="index">
              <div class="flex gap-2 mb-2">
                <input type="email" 
                       x-model="email.email"
                       class="input input-bordered flex-1"
                       placeholder="email@exemplo.com" />
                <button type="button"
                        @click="removeEmail(index)"
                        class="btn btn-error btn-outline"
                        x-show="formData.emails.length > 1">
                  Remover
                </button>
              </div>
            </template>
            <button type="button" 
                    @click="addEmail"
                    class="btn btn-sm btn-primary btn-outline mt-2">
              + Adicionar E-mail
            </button>
          </div>

          <!-- Login Credentials Section -->
          <div class="divider">Credenciais de Acesso</div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Login Email -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">E-mail de Login <span x-show="formData.capacity !== 'unable'">*</span></span>
              </label>
              <input type="email" 
                     x-model="formData.customer_email"
                     @blur="validateField('customer_email', formData.customer_email)"
                     class="input input-bordered w-full"
                     :class="{ 'input-error': errors.customer_email && touched.customer_email }"
                     placeholder="email@exemplo.com"
                     :disabled="formData.capacity === 'unable'" />
              <label class="label" x-show="errors.customer_email && touched.customer_email">
                <span class="label-text-alt text-error" x-text="errors.customer_email"></span>
              </label>
            </div>

            <!-- Password -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">Senha *</span>
              </label>
              <div class="relative">
                <input :type="showPassword ? 'text' : 'password'" 
                       x-model="formData.password"
                       @blur="validateField('password', formData.password)"
                       class="input input-bordered w-full pr-10"
                       :class="{ 'input-error': errors.password && touched.password }"
                       placeholder="Digite a senha" />
                <button type="button"
                        @click="showPassword = !showPassword"
                        class="absolute right-2 top-1/2 -translate-y-1/2">
                  <span x-show="!showPassword">👁</span>
                  <span x-show="showPassword">👁‍🗨</span>
                </button>
              </div>
              <label class="label" x-show="errors.password && touched.password">
                <span class="label-text-alt text-error" x-text="errors.password"></span>
              </label>
            </div>

            <!-- Password Confirmation -->
            <div class="form-control w-full">
              <label class="label">
                <span class="label-text">Confirmar Senha *</span>
              </label>
              <input :type="showPassword ? 'text' : 'password'" 
                     x-model="formData.password_confirmation"
                     @blur="validateField('password_confirmation', formData.password_confirmation)"
                     class="input input-bordered w-full"
                     :class="{ 'input-error': errors.password_confirmation && touched.password_confirmation }"
                     placeholder="Confirme a senha" />
              <label class="label" x-show="errors.password_confirmation && touched.password_confirmation">
                <span class="label-text-alt text-error" x-text="errors.password_confirmation"></span>
              </label>
            </div>

            <!-- Generate Password Button -->
            <div class="form-control">
              <label class="label">
                <span class="label-text">&nbsp;</span>
              </label>
              <button type="button"
                      @click="generatePassword"
                      class="btn btn-outline btn-info">
                Gerar Senha Forte
              </button>
            </div>
          </div>

          <!-- Address Section -->
          <div class="divider">Endereços</div>

          <template x-for="(address, index) in formData.addresses" :key="index">
            <div class="border rounded-lg p-4 mb-4">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control w-full">
                  <label class="label">
                    <span class="label-text">CEP</span>
                  </label>
                  <input type="text" 
                         x-model="address.zip_code"
                         @blur="fetchAddressByCEP(address.zip_code, index)"
                         class="input input-bordered w-full"
                         placeholder="00000-000" />
                </div>

                <div class="form-control w-full">
                  <label class="label">
                    <span class="label-text">Rua</span>
                  </label>
                  <input type="text" 
                         x-model="address.street"
                         class="input input-bordered w-full"
                         placeholder="Nome da rua" />
                </div>

                <div class="form-control w-full">
                  <label class="label">
                    <span class="label-text">Número</span>
                  </label>
                  <input type="text" 
                         x-model="address.number"
                         class="input input-bordered w-full"
                         placeholder="Número" />
                </div>

                <div class="form-control w-full">
                  <label class="label">
                    <span class="label-text">Bairro</span>
                  </label>
                  <input type="text" 
                         x-model="address.neighborhood"
                         class="input input-bordered w-full"
                         placeholder="Bairro" />
                </div>

                <div class="form-control w-full">
                  <label class="label">
                    <span class="label-text">Cidade</span>
                  </label>
                  <input type="text" 
                         x-model="address.city"
                         class="input input-bordered w-full"
                         placeholder="Cidade" />
                </div>

                <div class="form-control w-full">
                  <label class="label">
                    <span class="label-text">Estado</span>
                  </label>
                  <select x-model="address.state" class="select select-bordered w-full">
                    <option value="">Selecione</option>
                    <option value="AC">Acre</option>
                    <option value="AL">Alagoas</option>
                    <option value="AP">Amapá</option>
                    <option value="AM">Amazonas</option>
                    <option value="BA">Bahia</option>
                    <option value="CE">Ceará</option>
                    <option value="DF">Distrito Federal</option>
                    <option value="ES">Espírito Santo</option>
                    <option value="GO">Goiás</option>
                    <option value="MA">Maranhão</option>
                    <option value="MT">Mato Grosso</option>
                    <option value="MS">Mato Grosso do Sul</option>
                    <option value="MG">Minas Gerais</option>
                    <option value="PA">Pará</option>
                    <option value="PB">Paraíba</option>
                    <option value="PR">Paraná</option>
                    <option value="PE">Pernambuco</option>
                    <option value="PI">Piauí</option>
                    <option value="RJ">Rio de Janeiro</option>
                    <option value="RN">Rio Grande do Norte</option>
                    <option value="RS">Rio Grande do Sul</option>
                    <option value="RO">Rondônia</option>
                    <option value="RR">Roraima</option>
                    <option value="SC">Santa Catarina</option>
                    <option value="SP">São Paulo</option>
                    <option value="SE">Sergipe</option>
                    <option value="TO">Tocantins</option>
                  </select>
                </div>
              </div>

              <button type="button"
                      @click="removeAddress(index)"
                      class="btn btn-error btn-outline mt-4"
                      x-show="formData.addresses.length > 1">
                Remover Endereço
              </button>
            </div>
          </template>

          <button type="button" 
                  @click="addAddress"
                  class="btn btn-primary btn-outline">
            + Adicionar Endereço
          </button>
        </div>

        <!-- Step 2: Guardian/Representative Information -->
        <div x-show="currentStep === 2 && showGuardianForm">
          <div class="alert alert-info mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span>Preencha os dados do <span x-text="guardianLabel"></span> responsável</span>
          </div>

          <!-- Guardian form fields (similar structure to step 1) -->
          <!-- This would duplicate the form fields for the guardian -->
          <!-- For brevity, I'll add a placeholder -->
          <div class="text-center py-8">
            <p class="text-lg">Formulário do <span x-text="guardianLabel"></span></p>
            <p class="text-sm text-gray-500">Implementação similar ao formulário do cliente</p>
          </div>
        </div>

        <!-- Form Actions -->
        <div class="card-actions justify-end mt-6">
          <button type="button"
                  @click="previousStep"
                  class="btn btn-ghost"
                  x-show="currentStep > 1">
            Voltar
          </button>
          
          <button type="button"
                  @click="cancel"
                  class="btn btn-ghost">
            Cancelar
          </button>

          <button type="submit"
                  class="btn btn-primary"
                  :disabled="isLoading">
            <span x-show="isLoading" class="loading loading-spinner"></span>
            <span x-show="!showGuardianForm && !isLoading">Criar Cliente</span>
            <span x-show="showGuardianForm && currentStep === 1 && !isLoading">Próximo</span>
            <span x-show="showGuardianForm && currentStep === 2 && !isLoading">Criar Cliente e Responsável</span>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function customerForm() {
  return {
    currentStep: 1,
    showGuardianForm: false,
    guardianLabel: '',
    isLoading: false,
    showPassword: false,
    
    formData: {
      customer_type: 'physical_person',
      name: '',
      last_name: '',
      cpf: '',
      cnpj: '',
      rg: '',
      birth: '',
      gender: '',
      civil_status: '',
      capacity: 'able',
      mother_name: '',
      profession: '',
      customer_email: '',
      password: '',
      password_confirmation: '',
      phones: [{ phone_number: '' }],
      emails: [{ email: '' }],
      addresses: [{
        zip_code: '',
        street: '',
        number: '',
        neighborhood: '',
        city: '',
        state: ''
      }]
    },
    
    guardianFormData: {},
    
    errors: {},
    touched: {},
    
    init() {
      // Load saved form data from localStorage
      const savedData = localStorage.getItem('customerFormDraft');
      if (savedData) {
        const parsed = JSON.parse(savedData);
        this.formData = { ...this.formData, ...parsed };
      }
      
      // Auto-save form data
      this.$watch('formData', () => {
        localStorage.setItem('customerFormDraft', JSON.stringify(this.formData));
      }, { deep: true });
    },
    
    handleCapacityChange() {
      if (this.formData.capacity === 'unable' || this.formData.capacity === 'relatively_incapable') {
        this.showGuardianForm = true;
        this.guardianLabel = this.formData.capacity === 'unable' ? 'Representante' : 'Assistente';
        this.guardianFormData = { ...this.formData };
      } else {
        this.showGuardianForm = false;
      }
      
      // Clear email if capacity is unable
      if (this.formData.capacity === 'unable') {
        this.formData.customer_email = '';
      }
    },
    
    handleBirthDateChange() {
      this.validateField('birth', this.formData.birth);
      // Auto-set capacity based on age if needed
      const birthDate = new Date(this.formData.birth);
      const age = Math.floor((new Date() - birthDate) / (365.25 * 24 * 60 * 60 * 1000));
      
      if (age < 16) {
        this.formData.capacity = 'unable';
        this.handleCapacityChange();
      } else if (age >= 16 && age < 18) {
        this.formData.capacity = 'relatively_incapable';
        this.handleCapacityChange();
      }
    },
    
    validateField(field, value) {
      this.touched[field] = true;
      
      // Basic validation rules
      const validationRules = {
        name: () => value ? '' : 'Nome é obrigatório',
        last_name: () => value ? '' : 'Sobrenome é obrigatório',
        cpf: () => this.validateCPF(value),
        cnpj: () => this.validateCNPJ(value),
        rg: () => value ? '' : 'RG é obrigatório',
        birth: () => value ? '' : 'Data de nascimento é obrigatória',
        mother_name: () => value ? '' : 'Nome da mãe é obrigatório',
        profession: () => {
          if (this.formData.capacity === 'unable') return '';
          return value ? '' : 'Profissão é obrigatória';
        },
        customer_email: () => {
          if (this.formData.capacity === 'unable' && !value) return '';
          return this.validateEmail(value);
        },
        password: () => value && value.length >= 6 ? '' : 'Senha deve ter pelo menos 6 caracteres',
        password_confirmation: () => value === this.formData.password ? '' : 'As senhas não coincidem'
      };
      
      if (validationRules[field]) {
        this.errors[field] = validationRules[field]();
      }
    },
    
    validateCPF(cpf) {
      cpf = cpf.replace(/[^\d]/g, '');
      if (cpf.length !== 11) return 'CPF inválido';
      
      // CPF validation algorithm
      if (/^(\d)\1{10}$/.test(cpf)) return 'CPF inválido';
      
      let sum = 0;
      for (let i = 0; i < 9; i++) {
        sum += parseInt(cpf.charAt(i)) * (10 - i);
      }
      let digit = 11 - (sum % 11);
      if (digit >= 10) digit = 0;
      if (digit !== parseInt(cpf.charAt(9))) return 'CPF inválido';
      
      sum = 0;
      for (let i = 0; i < 10; i++) {
        sum += parseInt(cpf.charAt(i)) * (11 - i);
      }
      digit = 11 - (sum % 11);
      if (digit >= 10) digit = 0;
      if (digit !== parseInt(cpf.charAt(10))) return 'CPF inválido';
      
      return '';
    },
    
    validateCNPJ(cnpj) {
      cnpj = cnpj.replace(/[^\d]/g, '');
      if (cnpj.length !== 14) return 'CNPJ inválido';
      
      // CNPJ validation would go here
      // For brevity, returning empty (valid)
      return '';
    },
    
    validateEmail(email) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return emailRegex.test(email) ? '' : 'E-mail inválido';
    },
    
    formatCPF(value) {
      const numbers = value.replace(/\D/g, '');
      if (numbers.length <= 11) {
        return numbers
          .replace(/(\d{3})(\d)/, '$1.$2')
          .replace(/(\d{3})(\d)/, '$1.$2')
          .replace(/(\d{3})(\d{1,2})/, '$1-$2');
      }
      return value.slice(0, 14);
    },
    
    formatCNPJ(value) {
      const numbers = value.replace(/\D/g, '');
      if (numbers.length <= 14) {
        return numbers
          .replace(/(\d{2})(\d)/, '$1.$2')
          .replace(/(\d{3})(\d)/, '$1.$2')
          .replace(/(\d{3})(\d)/, '$1/$2')
          .replace(/(\d{4})(\d{1,2})/, '$1-$2');
      }
      return value.slice(0, 18);
    },
    
    formatPhone(value) {
      const numbers = value.replace(/\D/g, '');
      if (numbers.length <= 11) {
        return numbers
          .replace(/(\d{2})(\d)/, '($1) $2')
          .replace(/(\d{5})(\d)/, '$1-$2');
      }
      return value.slice(0, 15);
    },
    
    generatePassword() {
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
      let password = '';
      for (let i = 0; i < 12; i++) {
        password += chars.charAt(Math.floor(Math.random() * chars.length));
      }
      this.formData.password = password;
      this.formData.password_confirmation = password;
      this.showPassword = true;
    },
    
    addPhone() {
      this.formData.phones.push({ phone_number: '' });
    },
    
    removePhone(index) {
      if (this.formData.phones.length > 1) {
        this.formData.phones.splice(index, 1);
      }
    },
    
    addEmail() {
      this.formData.emails.push({ email: '' });
    },
    
    removeEmail(index) {
      if (this.formData.emails.length > 1) {
        this.formData.emails.splice(index, 1);
      }
    },
    
    addAddress() {
      this.formData.addresses.push({
        zip_code: '',
        street: '',
        number: '',
        neighborhood: '',
        city: '',
        state: ''
      });
    },
    
    removeAddress(index) {
      if (this.formData.addresses.length > 1) {
        this.formData.addresses.splice(index, 1);
      }
    },
    
    async fetchAddressByCEP(cep, index) {
      cep = cep.replace(/\D/g, '');
      if (cep.length === 8) {
        try {
          const response = await fetch(`https://viacep.com.br/ws/${cep}/json/`);
          const data = await response.json();
          if (!data.erro) {
            this.formData.addresses[index] = {
              ...this.formData.addresses[index],
              street: data.logradouro,
              neighborhood: data.bairro,
              city: data.localidade,
              state: data.uf
            };
          }
        } catch (error) {
          console.error('Error fetching address:', error);
        }
      }
    },
    
    validateForm() {
      // Validate all required fields
      const requiredFields = ['name', 'last_name', 'rg', 'birth', 'mother_name'];
      
      if (this.formData.customer_type === 'physical_person') {
        requiredFields.push('cpf');
      } else {
        requiredFields.push('cnpj');
      }
      
      if (this.formData.capacity !== 'unable') {
        requiredFields.push('profession', 'customer_email');
      }
      
      requiredFields.push('password', 'password_confirmation');
      
      let isValid = true;
      requiredFields.forEach(field => {
        this.validateField(field, this.formData[field]);
        if (this.errors[field]) {
          isValid = false;
        }
      });
      
      return isValid;
    },
    
    nextStep() {
      if (this.validateForm()) {
        this.currentStep++;
      }
    },
    
    previousStep() {
      if (this.currentStep > 1) {
        this.currentStep--;
      }
    },
    
    cancel() {
      if (confirm('Tem certeza que deseja cancelar? Os dados preenchidos serão salvos.')) {
        window.location.href = '/customers';
      }
    },
    
    async handleSubmit() {
      if (this.showGuardianForm && this.currentStep === 1) {
        this.nextStep();
        return;
      }
      
      if (!this.validateForm()) {
        return;
      }
      
      this.isLoading = true;
      
      // Clear draft after successful submission
      localStorage.removeItem('customerFormDraft');
      
      // Submit the form using Turbo
      const form = event.target;
      const formData = new FormData(form);
      
      // Add our custom data to the form
      Object.keys(this.formData).forEach(key => {
        if (typeof this.formData[key] === 'object') {
          formData.append(`customer[${key}]`, JSON.stringify(this.formData[key]));
        } else {
          formData.append(`customer[${key}]`, this.formData[key]);
        }
      });
      
      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content,
            'Accept': 'text/vnd.turbo-stream.html, text/html'
          }
        });
        
        if (response.ok) {
          window.location.href = '/customers';
        } else {
          // Handle errors
          this.isLoading = false;
        }
      } catch (error) {
        console.error('Error submitting form:', error);
        this.isLoading = false;
      }
    }
  }
}
</script>