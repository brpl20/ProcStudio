<div class="container">
  <div class="page-header">
    <h1>Editar Usuário</h1>
    <%= link_to "Voltar", users_path, class: "btn btn-secondary" %>
  </div>

  <div class="form-container">
    <% if flash[:alert] %>
      <div class="alert alert-error">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with model: @user, local: true, class: "user-form" do |f| %>
      <div class="form-section">
        <h3>Dados de Acesso</h3>
        
        <div class="form-group">
          <%= f.label :email, "E-mail", class: "form-label" %>
          <%= f.email_field :email, class: "form-input", required: true %>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :password, "Nova Senha", class: "form-label" %>
            <%= f.password_field :password, class: "form-input" %>
            <small class="form-hint">Deixe em branco para manter a senha atual</small>
          </div>

          <div class="form-group">
            <%= f.label :password_confirmation, "Confirmar Nova Senha", class: "form-label" %>
            <%= f.password_field :password_confirmation, class: "form-input" %>
          </div>
        </div>

        <div class="form-group">
          <%= f.label :oab, "OAB", class: "form-label" %>
          <%= f.text_field :oab, class: "form-input", placeholder: "PR_54159", value: @user.oab %>
        </div>
      </div>

      <% if @user.user_profile %>
        <%= f.fields_for :profile, @user.user_profile do |profile_fields| %>
          <div class="form-section">
            <h3>Dados Pessoais</h3>
            
            <div class="form-row">
              <div class="form-group">
                <%= profile_fields.label :name, "Nome", class: "form-label" %>
                <%= profile_fields.text_field :name, class: "form-input", required: true %>
              </div>

              <div class="form-group">
                <%= profile_fields.label :last_name, "Sobrenome", class: "form-label" %>
                <%= profile_fields.text_field :last_name, class: "form-input", required: true %>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <%= profile_fields.label :cpf, "CPF", class: "form-label" %>
                <%= profile_fields.text_field :cpf, class: "form-input", required: true, 
                    placeholder: "000.000.000-00" %>
              </div>

              <div class="form-group">
                <%= profile_fields.label :rg, "RG", class: "form-label" %>
                <%= profile_fields.text_field :rg, class: "form-input", required: true %>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <%= profile_fields.label :birth, "Data de Nascimento", class: "form-label" %>
                <%= profile_fields.date_field :birth, class: "form-input", required: true %>
              </div>

              <div class="form-group">
                <%= profile_fields.label :gender, "Gênero", class: "form-label" %>
                <%= profile_fields.select :gender, 
                    options_for_select([
                      ["Masculino", "male"],
                      ["Feminino", "female"],
                      ["Outro", "other"]
                    ], @user.user_profile.gender), 
                    { prompt: "Selecione..." }, 
                    class: "form-input", required: true %>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <%= profile_fields.label :civil_status, "Estado Civil", class: "form-label" %>
                <%= profile_fields.select :civil_status,
                    options_for_select([
                      ["Solteiro(a)", "single"],
                      ["Casado(a)", "married"],
                      ["Divorciado(a)", "divorced"],
                      ["Viúvo(a)", "widowed"]
                    ], @user.user_profile.civil_status),
                    { prompt: "Selecione..." },
                    class: "form-input", required: true %>
              </div>

              <div class="form-group">
                <%= profile_fields.label :nationality, "Nacionalidade", class: "form-label" %>
                <%= profile_fields.text_field :nationality, class: "form-input", required: true %>
              </div>
            </div>

            <div class="form-group">
              <%= profile_fields.label :role, "Função", class: "form-label" %>
              <%= profile_fields.select :role,
                  options_for_select([
                    ["Advogado", "lawyer"],
                    ["Administrador", "admin"],
                    ["Secretário", "secretary"],
                    ["Estagiário", "intern"]
                  ], @user.user_profile.role),
                  { prompt: "Selecione..." },
                  class: "form-input", required: true %>
            </div>
          </div>
        <% end %>
      <% end %>

      <div class="form-actions">
        <%= f.submit "Atualizar Usuário", class: "btn btn-primary" %>
        <%= link_to "Cancelar", user_path(@user), class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>