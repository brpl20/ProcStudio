<!DOCTYPE html>
<html lang="en" data-theme="procstudio">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Style Test - Procstudio Theme</title>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
</head>
<body class="bg-snow">
  <div class="container-custom py-8">
    <!-- Header -->
    <header class="mb-12">
      <h1 class="text-gradient mb-4">Procstudio Style Test</h1>
      <p class="text-gray-medium">Testing Tailwind CSS, DaisyUI, and custom color palette</p>
    </header>

    <!-- Flash Messages -->
    <% if flash.any? %>
      <div class="mb-8 space-y-4">
        <% flash.each do |type, message| %>
          <% css_class = case type.to_sym
             when :notice then "alert-success-custom"
             when :error then "alert-error-custom"
             when :warning then "alert-warning-custom"
             when :info then "alert-info-custom"
             else "alert-info-custom"
             end %>
          <div class="<%= css_class %> animate-fade-in">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Color Palette Section -->
    <section class="section-custom">
      <h2 class="mb-8 text-charcoal">Color Palette</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4">
        <% @test_data[:colors].each do |color| %>
          <div class="card-custom card-hover text-center">
            <div class="<%= color[:class] %> w-full h-20 rounded-md mb-2 border border-pearl"></div>
            <p class="text-sm font-medium text-charcoal"><%= color[:name] %></p>
            <p class="text-xs text-gray-medium"><%= color[:value] %></p>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Test Form Section -->
    <section class="section-custom">
      <h2 class="mb-8 text-charcoal">Form Components Test</h2>
      
      <div class="card-custom max-w-2xl mx-auto">
        <%= form_with url: style_test_form_test_path, method: :post, local: true, class: "space-y-6" do |f| %>
          <!-- Text Input -->
          <div class="form-group">
            <label class="form-label-custom">
              Text Input
            </label>
            <input type="text" 
                   name="text_field" 
                   placeholder="Enter some text..."
                   class="form-input-custom">
          </div>

          <!-- Email Input with DaisyUI -->
          <div class="form-group">
            <label class="form-label-custom">
              Email (DaisyUI styled)
            </label>
            <input type="email" 
                   name="email_field" 
                   placeholder="email@example.com"
                   class="input input-bordered w-full">
          </div>

          <!-- Select Dropdown -->
          <div class="form-group">
            <label class="form-label-custom">
              Select Option
            </label>
            <select name="select_field" class="select select-bordered w-full">
              <option disabled selected>Choose an option</option>
              <option value="option1">Option 1</option>
              <option value="option2">Option 2</option>
              <option value="option3">Option 3</option>
            </select>
          </div>

          <!-- Textarea -->
          <div class="form-group">
            <label class="form-label-custom">
              Message
            </label>
            <textarea name="message_field" 
                      rows="4" 
                      placeholder="Enter your message..."
                      class="textarea textarea-bordered w-full"></textarea>
          </div>

          <!-- Checkbox Group -->
          <div class="form-group">
            <label class="form-label-custom mb-3">
              Checkboxes (DaisyUI)
            </label>
            <div class="space-y-2">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="check1" class="checkbox checkbox-primary">
                <span class="text-charcoal">Primary checkbox</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="check2" class="checkbox checkbox-secondary">
                <span class="text-charcoal">Secondary checkbox</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="check3" class="checkbox checkbox-accent">
                <span class="text-charcoal">Accent checkbox</span>
              </label>
            </div>
          </div>

          <!-- Radio Buttons -->
          <div class="form-group">
            <label class="form-label-custom mb-3">
              Radio Options
            </label>
            <div class="space-y-2">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="radio_option" value="1" class="radio radio-primary">
                <span class="text-charcoal">Option 1</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="radio_option" value="2" class="radio radio-secondary">
                <span class="text-charcoal">Option 2</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="radio_option" value="3" class="radio radio-accent">
                <span class="text-charcoal">Option 3</span>
              </label>
            </div>
          </div>

          <!-- Toggle Switch -->
          <div class="form-group">
            <label class="flex items-center gap-3 cursor-pointer">
              <span class="form-label-custom mb-0">Enable notifications</span>
              <input type="checkbox" name="toggle" class="toggle toggle-primary">
            </label>
          </div>

          <!-- Range Slider -->
          <div class="form-group">
            <label class="form-label-custom">
              Range Slider
            </label>
            <input type="range" min="0" max="100" value="40" class="range range-primary">
            <div class="w-full flex justify-between text-xs px-2 text-gray-medium">
              <span>0</span>
              <span>25</span>
              <span>50</span>
              <span>75</span>
              <span>100</span>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Button Showcase -->
    <section class="section-custom">
      <h2 class="mb-8 text-charcoal">Button Components</h2>
      
      <div class="space-y-8">
        <!-- Custom Buttons -->
        <div>
          <h3 class="mb-4 text-charcoal">Custom Styled Buttons</h3>
          <div class="flex flex-wrap gap-4">
            <%= form_with url: style_test_form_test_path, method: :post, local: true, class: "inline" do |f| %>
              <input type="hidden" name="submit_action" value="submit">
              <button type="submit" class="btn-primary-custom hover-lift">
                Primary Button
              </button>
            <% end %>
            
            <%= form_with url: style_test_form_test_path, method: :post, local: true, class: "inline" do |f| %>
              <input type="hidden" name="submit_action" value="error">
              <button type="submit" class="btn-secondary-custom hover-lift">
                Secondary Button
              </button>
            <% end %>
            
            <%= form_with url: style_test_form_test_path, method: :post, local: true, class: "inline" do |f| %>
              <input type="hidden" name="submit_action" value="warning">
              <button type="submit" class="btn-accent-custom hover-lift">
                Accent Button
              </button>
            <% end %>
          </div>
        </div>

        <!-- DaisyUI Buttons -->
        <div>
          <h3 class="mb-4 text-charcoal">DaisyUI Buttons</h3>
          <div class="flex flex-wrap gap-4">
            <button class="btn btn-primary">Primary</button>
            <button class="btn btn-secondary">Secondary</button>
            <button class="btn btn-accent">Accent</button>
            <button class="btn btn-success">Success</button>
            <button class="btn btn-warning">Warning</button>
            <button class="btn btn-error">Error</button>
            <button class="btn btn-info">Info</button>
            <button class="btn btn-ghost">Ghost</button>
            <button class="btn btn-link">Link</button>
          </div>
        </div>

        <!-- Button Sizes -->
        <div>
          <h3 class="mb-4 text-charcoal">Button Sizes</h3>
          <div class="flex flex-wrap gap-4 items-center">
            <button class="btn btn-primary btn-xs">Extra Small</button>
            <button class="btn btn-primary btn-sm">Small</button>
            <button class="btn btn-primary btn-md">Medium</button>
            <button class="btn btn-primary btn-lg">Large</button>
          </div>
        </div>

        <!-- Button States -->
        <div>
          <h3 class="mb-4 text-charcoal">Button States</h3>
          <div class="flex flex-wrap gap-4">
            <button class="btn btn-primary" disabled>Disabled</button>
            <button class="btn btn-primary loading">Loading</button>
            <button class="btn btn-primary btn-outline">Outlined</button>
            <button class="btn btn-primary btn-wide">Wide</button>
            <button class="btn btn-primary btn-circle">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Badge Examples -->
    <section class="section-custom">
      <h2 class="mb-8 text-charcoal">Badges & Tags</h2>
      
      <div class="space-y-4">
        <!-- Custom Badges -->
        <div>
          <h3 class="mb-4 text-charcoal">Custom Badges</h3>
          <div class="flex flex-wrap gap-3">
            <span class="badge-custom badge-primary">Primary</span>
            <span class="badge-custom badge-success">Success</span>
            <span class="badge-custom badge-warning">Warning</span>
            <span class="badge-custom badge-error">Error</span>
          </div>
        </div>

        <!-- DaisyUI Badges -->
        <div>
          <h3 class="mb-4 text-charcoal">DaisyUI Badges</h3>
          <div class="flex flex-wrap gap-3">
            <div class="badge badge-primary">primary</div>
            <div class="badge badge-secondary">secondary</div>
            <div class="badge badge-accent">accent</div>
            <div class="badge badge-success">success</div>
            <div class="badge badge-warning">warning</div>
            <div class="badge badge-error">error</div>
            <div class="badge badge-info">info</div>
            <div class="badge badge-ghost">ghost</div>
            <div class="badge badge-outline">outline</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Card Examples -->
    <section class="section-custom">
      <h2 class="mb-8 text-charcoal">Card Components</h2>
      
      <div class="grid-responsive">
        <!-- Custom Card -->
        <div class="card-custom card-hover hover-lift">
          <h3 class="text-xl font-semibold mb-3 text-charcoal">Custom Card</h3>
          <p class="text-gray-medium mb-4">This is a custom styled card using our Tailwind classes.</p>
          <button class="btn btn-primary btn-sm">Learn More</button>
        </div>

        <!-- DaisyUI Card -->
        <div class="card bg-base-100 shadow-xl">
          <div class="card-body">
            <h2 class="card-title text-charcoal">DaisyUI Card</h2>
            <p class="text-gray-medium">This card uses DaisyUI components with our theme.</p>
            <div class="card-actions justify-end">
              <button class="btn btn-primary">Action</button>
            </div>
          </div>
        </div>

        <!-- Gradient Card -->
        <div class="card bg-gradient-primary text-snow shadow-xl">
          <div class="card-body">
            <h2 class="card-title text-snow">Gradient Card</h2>
            <p class="text-snow/90">A card with gradient background using our colors.</p>
            <div class="card-actions justify-end">
              <button class="btn btn-ghost text-snow">Explore</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Modal Example -->
    <section class="section-custom">
      <h2 class="mb-8 text-charcoal">Modal Component</h2>
      
      <button class="btn btn-primary" onclick="document.getElementById('modal_test').showModal()">
        Open Modal
      </button>
      
      <dialog id="modal_test" class="modal">
        <div class="modal-box">
          <h3 class="font-bold text-lg text-charcoal">Test Modal</h3>
          <p class="py-4 text-gray-medium">This is a DaisyUI modal styled with our custom theme.</p>
          <div class="modal-action">
            <form method="dialog">
              <button class="btn btn-ghost mr-2">Cancel</button>
              <button class="btn btn-primary">Confirm</button>
            </form>
          </div>
        </div>
        <form method="dialog" class="modal-backdrop">
          <button>close</button>
        </form>
      </dialog>
    </section>

    <!-- Table Example -->
    <section class="section-custom">
      <h2 class="mb-8 text-charcoal">Table Component</h2>
      
      <div class="overflow-x-auto card-custom">
        <table class="table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Color</th>
              <th>Category</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <tr class="hover">
              <td>Azure Blue</td>
              <td><span class="badge badge-primary">#0277EE</span></td>
              <td>Primary</td>
              <td><button class="btn btn-ghost btn-xs">View</button></td>
            </tr>
            <tr class="hover">
              <td>Crimson Red</td>
              <td><span class="badge badge-secondary">#B5192B</span></td>
              <td>Secondary</td>
              <td><button class="btn btn-ghost btn-xs">View</button></td>
            </tr>
            <tr class="hover">
              <td>Forest Green</td>
              <td><span class="badge badge-success">#0B5F1F</span></td>
              <td>Success</td>
              <td><button class="btn btn-ghost btn-xs">View</button></td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Loading States -->
    <section class="section-custom">
      <h2 class="mb-8 text-charcoal">Loading States</h2>
      
      <div class="flex flex-wrap gap-8 items-center">
        <span class="loading loading-spinner loading-xs text-primary"></span>
        <span class="loading loading-spinner loading-sm text-secondary"></span>
        <span class="loading loading-spinner loading-md text-accent"></span>
        <span class="loading loading-spinner loading-lg text-success"></span>
        
        <span class="loading loading-dots loading-md text-info"></span>
        <span class="loading loading-ring loading-lg text-warning"></span>
        <span class="loading loading-ball loading-md text-error"></span>
        <span class="loading loading-bars loading-md text-primary"></span>
      </div>
    </section>

    <!-- Progress Bars -->
    <section class="section-custom">
      <h2 class="mb-8 text-charcoal">Progress Indicators</h2>
      
      <div class="space-y-4">
        <progress class="progress progress-primary w-full" value="20" max="100"></progress>
        <progress class="progress progress-secondary w-full" value="40" max="100"></progress>
        <progress class="progress progress-accent w-full" value="60" max="100"></progress>
        <progress class="progress progress-success w-full" value="80" max="100"></progress>
        <progress class="progress progress-warning w-full" value="90" max="100"></progress>
        <progress class="progress progress-error w-full" value="100" max="100"></progress>
      </div>
    </section>

    <!-- Toast Notifications -->
    <section class="section-custom">
      <h2 class="mb-8 text-charcoal">Toast Notifications</h2>
      
      <div class="space-y-4">
        <div class="alert alert-info">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>Info: New software update available.</span>
        </div>
        
        <div class="alert alert-success">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Success: Your purchase has been confirmed!</span>
        </div>
        
        <div class="alert alert-warning">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <span>Warning: Invalid email address!</span>
        </div>
        
        <div class="alert alert-error">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Error: Task failed successfully.</span>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="mt-16 pt-8 border-t border-pearl">
      <div class="text-center text-gray-medium">
        <p>Procstudio Theme Test Page</p>
        <p class="text-sm mt-2">Built with Tailwind CSS & DaisyUI</p>
      </div>
    </footer>
  </div>
</body>
</html>